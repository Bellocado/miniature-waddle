# ==============================================================================
# Pure Performance Sway Configuration - thickpad (User: bwello)
# ==============================================================================

### CORE VARIABLES ###
set $mod Mod4
set $term foot

### TYPOGRAPHY & WINDOW AESTHETICS (Super Nice Tiling) ###
font pango:monospace 10

# Seamless pixel borders and elegant inner/outer padding for modern tiling windows
default_border pixel 2
default_floating_border pixel 2
gaps inner 8
gaps outer 4

# Sleek, unified monochromatic frame color tones
set $cl_active #5c5c5c
set $cl_inactive #231f20

client.focused          $cl_active $cl_active #ffffff $cl_active $cl_active
client.focused_inactive $cl_inactive $cl_inactive #aaaaaa $cl_inactive $cl_inactive
client.unfocused        $cl_inactive $cl_inactive #aaaaaa $cl_inactive $cl_inactive

### HARDWARE & MULTILINGUAL INPUTS ###
input type:keyboard {
    xkb_layout pl
}
input type:touchpad {
    tap enabled
    natural_scroll enabled
    dwt enabled
}

### SCREEN DECORATION ###
# Pointed exactly to your custom PNG wallpaper asset
output * background '~/Pictures/Wallpapers/bg.png' fill

### --- MANDATORY KEYBINDINGS --- ###

# Win + Enter -> Launches your native foot terminal
bindsym $mod+Return exec $term

# Win + Q -> Instantly closes the focused window panel
bindsym $mod+q kill

# Win + Space -> Spawns your Rofi launcher overlay cleanly in run mode
bindsym $mod+space exec rofi -show run

# System Management Actions
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway session?' -b 'Yes' 'swaymsg exit'

### --- CONTAINER MANAGEMENT --- ###

# Focus Navigation Control (Arrow Keys)
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Window Relocation Control
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Workspace Switching (Win + 1 through 5)
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5

# Container Routing (Win + Shift + 1 through 5)
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5

# Splitting and Presenting Modes
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen

# Container Resize Submode
mode "resize" {
    bindsym Left resize shrink width 20px
    bindsym Down resize grow height 20px
    bindsym Up resize shrink height 20px
    bindsym Right resize grow width 20px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

### BAR FRAME WORK ###
# Extremely fast and ultra-clean minimal clock strip at the bottom of the screen
bar {
    position bottom
    status_command while date +'%Y-%m-%d │ %I:%M %p'; do sleep 1; done
    colors {
        statusline #ffffff
        background #1e1e1e
    }
}
